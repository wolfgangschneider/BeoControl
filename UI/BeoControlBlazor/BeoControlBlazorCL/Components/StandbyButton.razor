@using Microsoft.JSInterop
@implements IDisposable
@* Pure layout component — no service knowledge *@
@inject IJSRuntime JS

@*duplicate code!!!*@
<script>
    window.registerLongPress = function (element, dotnetRef, threshold = 600) {
        let timer;
        let moved = false;

        const start = () => {
            moved = false;
            timer = setTimeout(() => {
                if (!moved) {
                    dotnetRef.invokeMethodAsync("OnLongPress");
                }
            }, threshold);
        };

        const cancel = () => {
            clearTimeout(timer);
        };

        const move = () => {
            moved = true;
            clearTimeout(timer);
        };

        element.addEventListener("touchstart", start);
        element.addEventListener("touchend", cancel);
        element.addEventListener("touchmove", move);

        element.addEventListener("mousedown", (e) => {
            if (e.button === 0) start();
        });
        element.addEventListener("mouseup", cancel);
        element.addEventListener("mouseleave", cancel);
    };
</script>

<RemoteButton style=" color: #e83030;font-size: 12px;" @ref="remoteBtn" OnCommand="@((cmd) => OnCommand.InvokeAsync(cmd))" Caption="&#9679;" />
@code {
  
    private RemoteButton remoteBtn;

    private DotNetObjectReference<StandbyButton>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            // Jetzt hast du das echte DOM-Element:
            var element = remoteBtn.ElementRef;

            await JS.InvokeVoidAsync(
                "registerLongPress",
                element,
                _dotNetRef,
                2000
            );
        }

    }
   

    [Parameter] public EventCallback<string> OnCommand { get; set; } = default!;

    [JSInvokable]
    public void OnLongPress()
    {
        OnCommand.InvokeAsync("allstandby");
        //OnCommand.InvokeAsync("mute");
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
