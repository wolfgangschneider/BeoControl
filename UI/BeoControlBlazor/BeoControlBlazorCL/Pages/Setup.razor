@page "/setup"
@using BeoControlBlazor.Services
@using BeoControl.Interfaces
@using BeoControlBlazorCL.Components
@using BeoControlBlazorServices
@using Microsoft.AspNetCore.Components.Forms
@using Spotify
@inject DeviceService DeviceService
@inject IAutostartRegistrationService AutostartRegistrationService
@inject NavigationManager Nav
@implements IDisposable


<PageTitle>Setup</PageTitle>

<div style="width:var(--body-width); margin:0 auto;" class="setup">

    <div class="setup-header">
        <button class="setup-back" @onclick='() => Nav.NavigateTo("/")'>&#8592;</button>
        <span class="setup-title">DEVICE SETUP</span>
    </div>

    <div class="setup-status @DisplayStatusClass">
        <span class="setup-dot @DisplayDotClass"></span>
        <span class="setup-status-text">@DisplayStatusText</span>
        @if (DeviceService.IsConnected && DeviceService.CurrentDevice is { } info)
        {
            <strong class="setup-device-name">@(info.Name ?? info.Id)</strong>
            <button class="setup-btn setup-btn-outline" @onclick="Disconnect">DISCONNECT</button>
        }
    </div>

    <div class="setup-tabs">
        @foreach (var tab in Tabs)
        {
            <button class="setup-tab @(ActiveTab == tab ? "active" : "")" @onclick="() => SelectTab(tab)">
                @TabLabel(tab)
            </button>
        }
    </div>

    <div class="setup-panel">

        

        @if (ActiveTab == DeviceType.USB)
        {
            <div class="setup-actions">
                <button class="setup-btn" @onclick="ScanSerial" disabled="@IsScanning">
                    @if (IsScanning) { <span class="setup-spinner"></span> }
                    SCAN
                </button>
            </div>
            @if (SerialDevices.Count > 0)
            {
                <div class="setup-list">
                    @foreach (var d in SerialDevices)
                    {
                        <button class="setup-list-item @(SelectedSerial == d.Id ? "active" : "")"
                                @onclick='() => ConnectSerial(d.Id)'
                                disabled="@IsBusy">
                            <span class="setup-list-id">@d.Id</span>
                            @if (d.Name is not null) { <span class="setup-list-name">@d.Name</span> }
                        </button>
                    }
                </div>
            }
            else if (!IsScanning)
            {
                <p class="setup-hint">Press SCAN to discover USB devices.</p>
            }
        }

        @if (ActiveTab == DeviceType.BT)
        {
            <div class="setup-actions">
                <button class="setup-btn" @onclick="ScanBluetooth" disabled="@IsScanning">
                    @if (IsScanning) { <span class="setup-spinner"></span> }
                    SCAN
                </button>
            </div>
            @if (BtDevices.Count > 0)
            {
                <div class="setup-list">
                    @foreach (var d in BtDevices)
                    {
                        <button class="setup-list-item @(SelectedBt == d.Id ? "active" : "")"
                                @onclick='() => ConnectBluetooth(d.Id)'
                                disabled="@IsBusy">
                            <span class="setup-list-id">@(d.Name ?? "Unknown")</span>
                        </button>
                    }
                </div>
            }
            else if (!IsScanning)
            {
                <p class="setup-hint">Press SCAN to discover Bluetooth (BLE) devices.</p>
            }
        }

        @if (ActiveTab == DeviceType.PC2)
        {
            @if (!IsPc2Connected )
            {
                <div class="setup-actions">
                    <button class="setup-btn" @onclick="ScanPc2" disabled="@IsScanning">
                        @if (IsScanning) { <span class="setup-spinner"></span> }
                        SCAN
                    </button>
                </div>
                     @if (Pc2Available )
                    {
                        <div class="setup-list">
                            <button class="setup-list-item active )"
                            @onclick="ConnectPc2" disabled="@IsBusy">
                                @if (IsBusy) { <span class="setup-spinner"></span> }
                                CONNECT PC2 bbb
                            </button>
                        </div>
                    } 
                
            <p class="setup-hint">Connect directly via USB / Masterlink (PC2 controller).</p>
            }
            else
            {
                <PC2Setup />
            }
           
        }

        @if (!string.IsNullOrEmpty(ScanStatus))
        {
            <p class="setup-scan-status">@ScanStatus</p>
        }

        <section class="setup-card">
            <div class="setup-card-header">
                <div>
                    <h3 class="setup-card-title">Remote zoom</h3>
                    <p class="setup-card-subtitle">Choose the button scale factor for the remote UI.</p>
                </div>
            </div>

            <InputRadioGroup @bind-Value="RemoteButtonZoom" Name="remote-button-zoom">
                <div class="setup-choice-grid setup-choice-grid-zoom">
                    @foreach (var option in ZoomOptions)
                    {
                        <label class="setup-choice @(RemoteButtonZoom == option.Value ? "active" : "")">
                            <InputRadio class="setup-radio" Value="option.Value" />
                            <span>@option.Label</span>
                        </label>
                    }
                </div>
            </InputRadioGroup>
        </section>

        <section class="setup-card">
            <div class="setup-card-header">
                <div>
                    <h3 class="setup-card-title">Windows autostart</h3>
                    <p class="setup-card-subtitle">Launch BeoControl with Windows using <code>/silent</code> so it starts hidden in the tray.</p>
                </div>
            </div>

            @if (AutostartRegistrationService.IsSupported)
            {
                <label class="setup-choice">
                    <input type="checkbox" @bind="_launchOnWindowsSignIn" @bind:after="OnAutostartChanged" />
                    <span>Start with Windows</span>
                </label>
            }
            else
            {
                <p class="setup-hint">Autostart can only be configured in the Windows MAUI app.</p>
            }
        </section>

        <section class="setup-card">
            <div class="setup-card-header">
                <div>
                    <h3 class="setup-card-title">Spotify</h3>
                    <p class="setup-card-subtitle">Enable Spotify forwarding, choose the trigger source and select a Spotify device.</p>
                </div>
            </div>

            <div class="setup-form">
                <label class="setup-choice">
                    <input type="checkbox" @bind="SpotifyEnabled" @bind:after="OnSpotifyEnabledChanged" />
                    <span>Connect to Spotify</span>
                </label>

                <label class="setup-field">
                    <span class="setup-field-label">Trigger command</span>
                    <InputSelect class="setup-text-input" @bind-Value="SpotifyTriggerCommand" disabled="@(!SpotifyEnabled)">
                        @foreach (var source in SpotifyTriggerSources)
                        {
                            <option value="@source.Name">@FormatSpotifyTriggerSource(source.Name)</option>
                        }
                    </InputSelect>
                </label>

                <label class="setup-field">
                    <span class="setup-field-label">Preferred device name</span>
                    <input class="setup-text-input"
                           list="spotify-device-names"
                           @bind="SpotifyPreferredDeviceName"
                           disabled="@(!SpotifyEnabled || IsLoadingSpotifyDevices)" />
                    <datalist id="spotify-device-names">
                        @foreach (var deviceName in SpotifyDevices)
                        {
                            <option value="@deviceName"></option>
                        }
                    </datalist>
                </label>

                @if (SpotifyEnabled && !string.IsNullOrEmpty(SpotifyDevicesStatus))
                {
                    <p class="setup-hint">@SpotifyDevicesStatus</p>
                }
            </div>
        </section>

    </div>

    <div class="setup-footer">
        <span class="setup-brand">BANG &amp; OLUFSEN</span>
    </div>

</div>

@code {
    private static readonly DeviceType[] Tabs = [DeviceType.USB, DeviceType.BT, DeviceType.PC2];
    private static readonly (int Value, string Label)[] ZoomOptions =
    [
        (100, "1x"),
        (150, "1.5x"),
        (200, "2x"),
    ];
    private static readonly CommandInfo[] SpotifyTriggerSources =
        BeoCommands.All.Where(command => string.Equals(command.Category, "Source", StringComparison.Ordinal))
            .ToArray();

    private DeviceType ActiveTab;
    private bool IsScanning;
    private bool IsBusy;
    private string? SelectedSerial;
    private string? SelectedBt;
    private string ScanStatus = "";
    private List<DeviceInfo> SerialDevices = [];
    private List<DeviceInfo> BtDevices = [];
    private CancellationTokenSource? _scanCts;
    private int _remoteButtonZoom = 100;
    private bool _launchOnWindowsSignIn;
    private bool IsLoadingSpotifyDevices;
    private string SpotifyDevicesStatus = string.Empty;
    private List<string> SpotifyDevices = [];
    private string _spotifyPreferredDeviceName = string.Empty;

    private StatusType _statusType = StatusType.Idle;
    private bool Pc2Available;

    private bool IsPc2Connected =>
        DeviceService.IsConnected && DeviceService.CurrentDevice?.Type == DeviceType.PC2;

    private int RemoteButtonZoom
    {
        get => _remoteButtonZoom;
        set
        {
            if (_remoteButtonZoom == value)
                return;

            _remoteButtonZoom = value;
            RemoteButton.Zoom = value;
            DeviceService.Settings.RemoteButtonZoom = value;
            DeviceService.Settings.Save();
        }
    }

    private bool SpotifyEnabled
    {
        get => DeviceService.Settings.SpotifyEnabled;
        set
        {
            if (DeviceService.Settings.SpotifyEnabled == value)
                return;

            DeviceService.Settings.SpotifyEnabled = value;
            DeviceService.Settings.Save();
        }
    }

    private string SpotifyTriggerCommand
    {
        get => DeviceService.Settings.SpotifyTriggerCommand;
        set
        {
            var normalized = value?.Trim() ?? string.Empty;
            if (DeviceService.Settings.SpotifyTriggerCommand == normalized)
                return;

            DeviceService.Settings.SpotifyTriggerCommand = normalized;
            DeviceService.Settings.Save();
        }
    }

    private string SpotifyPreferredDeviceName
    {
        get => _spotifyPreferredDeviceName;
        set
        {
            var normalized = value?.Trim() ?? string.Empty;
            if (_spotifyPreferredDeviceName == normalized)
                return;

            _spotifyPreferredDeviceName = normalized;
            DeviceService.Settings.SpotifyPreferredDeviceName = normalized;
            DeviceService.Settings.Save();
        }
    }

    private string DisplayStatusText =>
        DeviceService.IsConnected ? "Connected" : "Disconnected";

    private string DisplayStatusClass =>
        DeviceService.IsConnected ? StatusClass : "status-disconnected";

    private string DisplayDotClass =>
        DeviceService.IsConnected ? DotClass : "dot-disconnected";

    private string StatusClass => _statusType switch
    {
        StatusType.Ok      => "status-ok",
        StatusType.Error   => "status-error",
        StatusType.Working => "status-working",
        _                  => "status-idle",
    };

    private string DotClass => _statusType switch
    {
        StatusType.Ok      => "dot-ok",
        StatusType.Error   => "dot-error",
        StatusType.Working => "dot-working",
        _                  => "dot-idle",
    };

    protected override void OnInitialized()
    {
        DeviceService.OnStatusChanged += OnServiceStatusChanged;
        ActiveTab      = DeviceService.Settings.LastDevice;
        SelectedSerial = DeviceService.Settings.LastSerial?.Id;
        SelectedBt     = DeviceService.Settings.LastBluetooth?.Id;
        _remoteButtonZoom = NormalizeZoom(DeviceService.Settings.RemoteButtonZoom);
        _spotifyPreferredDeviceName = DeviceService.Settings.SpotifyPreferredDeviceName;
        _launchOnWindowsSignIn = AutostartRegistrationService.IsEnabled();
        if (SpotifyEnabled)
            _ = LoadSpotifyDevicesAsync();
    }

    private async void OnServiceStatusChanged(StatusMessage msg)
    {
        if (msg.Kind is StatusKind.Source or StatusKind.AudioSetup)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        _statusType = msg.Type;
        await InvokeAsync(StateHasChanged);
    }

    private void SelectTab(DeviceType tab)
    {
        ActiveTab = tab;
        _scanCts?.Cancel();
        IsScanning = false;
        ScanStatus = "";
        if (tab != DeviceType.PC2)
            Pc2Available = false;
    }

    private async Task ScanSerial()
    {
        _scanCts?.Cancel();
        _scanCts = new CancellationTokenSource();
        IsScanning = true;
        SerialDevices = [];
        ScanStatus = "Scanning…";
        StateHasChanged();
        try
        {
            SerialDevices = await DeviceService.ScanSerialAsync(
                s => { ScanStatus = s; InvokeAsync(StateHasChanged); },
                _scanCts.Token);
            if (SerialDevices.Count > 0 && SelectedSerial is null)
                SelectedSerial = SerialDevices[0].Id;
            ScanStatus = $"Found {SerialDevices.Count} device(s).";
        }
        catch (OperationCanceledException) { ScanStatus = "Scan cancelled."; }
        catch (Exception ex)               { ScanStatus = $"Error: {ex.Message}"; }
        finally { IsScanning = false; StateHasChanged(); }
    }

    private async Task ScanBluetooth()
    {
        _scanCts?.Cancel();
        _scanCts = new CancellationTokenSource();
        IsScanning = true;
        BtDevices = [];
        ScanStatus = "Scanning…";
        StateHasChanged();
        try
        {
            BtDevices = await DeviceService.ScanBluetoothAsync(
                s => { ScanStatus = s; InvokeAsync(StateHasChanged); },
                _scanCts.Token);
            if (BtDevices is [{ Id: { } singleDeviceId }])
            {
                SelectedBt = singleDeviceId;
                ScanStatus = "Found 1 device. Connecting…";
                StateHasChanged();
                await ConnectBluetooth(SelectedBt);
                return;
            }

            if (BtDevices.Count > 0 && SelectedBt is null)
                SelectedBt = BtDevices[0].Id;
            ScanStatus = BtDevices.Count > 0
                ? $"Found {BtDevices.Count} device(s)."
                : GetBluetoothEmptyScanMessage();
        }
        catch (OperationCanceledException) { ScanStatus = "Scan cancelled."; }
        catch (Exception ex)               { ScanStatus = $"Error: {ex.Message}"; }
        finally { IsScanning = false; StateHasChanged(); }
    }

    private async Task ScanPc2()
    {
        _scanCts?.Cancel();
        _scanCts = new CancellationTokenSource();
        IsScanning = true;
        Pc2Available = false;
        ScanStatus = "Scanning…";
        StateHasChanged();
        try
        {
            var found = await DeviceService.ScanPc2Async(
                s => { ScanStatus = s; InvokeAsync(StateHasChanged); },
                _scanCts.Token);
            Pc2Available = found;
            ScanStatus = found ? "Found PC2 device." : "No PC2 device found.";
        }
        catch (OperationCanceledException) { ScanStatus = "Scan cancelled."; }
        catch (Exception ex)               { ScanStatus = $"Error: {ex.Message}"; }
        finally { IsScanning = false; StateHasChanged(); }
    }

    private async Task ConnectSerial(string? portName = null)
    {
        SelectedSerial = portName;
        IsBusy = true;
        StateHasChanged();
        await DeviceService.ConnectSerialAsync(portName);
        IsBusy = false;
        if (DeviceService.IsConnected) Nav.NavigateTo("/");
    }

    private async Task ConnectBluetooth(string? deviceId = null)
    {
        SelectedBt = deviceId;
        IsBusy = true;
        StateHasChanged();
        await DeviceService.ConnectBluetoothAsync(deviceId);
        IsBusy = false;
        if (DeviceService.IsConnected) Nav.NavigateTo("/");
    }

    private async Task ConnectPc2()
    {
        IsBusy = true;
        StateHasChanged();
        await DeviceService.ConnectPc2Async();
        IsBusy = false;
        Pc2Available = DeviceService.IsConnected && DeviceService.CurrentDevice?.Type == DeviceType.PC2;
        if (DeviceService.IsConnected) Nav.NavigateTo("/");
    }

    private void Disconnect() => DeviceService.Disconnect();

    private static string TabLabel(DeviceType t) => t switch
    {
        DeviceType.USB => "USB",
        DeviceType.BT     => "Bluetooth",
        DeviceType.PC2    => "PC2",
        _                 => t.ToString(),
    };

    private static int NormalizeZoom(int zoom) => zoom switch
    {
        100 or 150 or 200 => zoom,
        _ => 100
    };

    private static string GetBluetoothEmptyScanMessage()
    {
        if (!OperatingSystem.IsMacOS() && !OperatingSystem.IsMacCatalyst())
            return "Found 0 device(s).";

        return "No Bluetooth device selected. On macOS, Scan opens the Apple Bluetooth chooser. If it does not appear, check Bluetooth permission for the host app you launched this app from.";
    }

    private Task OnAutostartChanged()
    {
        AutostartRegistrationService.SetEnabled(_launchOnWindowsSignIn);
        return Task.CompletedTask;
    }

    private async Task OnSpotifyEnabledChanged()
    {
        if (!SpotifyEnabled)
        {
            IsLoadingSpotifyDevices = false;
            SpotifyDevicesStatus = string.Empty;
            SpotifyDevices = [];
            await InvokeAsync(StateHasChanged);
            return;
        }

        await LoadSpotifyDevicesAsync();
    }

    private async Task LoadSpotifyDevicesAsync()
    {
        IsLoadingSpotifyDevices = true;
        SpotifyDevicesStatus = "Loading Spotify devices…";
        await InvokeAsync(StateHasChanged);

        try
        {
            var connection = await SpotifyController.ConnectAsync(
                "d241779ec817475db4bf6b5bd0a457c7",
                "http://127.0.0.1:5543/callback");

            SpotifyDevices = connection.Devices
                .Select(device => device.Name)
                .Where(name => !string.IsNullOrWhiteSpace(name))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(name => name, StringComparer.OrdinalIgnoreCase)
                .ToList()!;

            SpotifyDevicesStatus = SpotifyDevices.Count == 0
                ? "No Spotify playback devices available."
                : string.Empty;
        }
        catch (Exception ex)
        {
            SpotifyDevices = [];
            SpotifyDevicesStatus = ex.Message;
        }
        finally
        {
            IsLoadingSpotifyDevices = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string FormatSpotifyTriggerSource(string sourceName) => sourceName.ToUpperInvariant() switch
    {
        "TV" => "TV",
        "RADIO" => "RADIO",
        "CD" => "CD",
        "CD2" => "CD 2",
        "PHONO" => "PHONO",
        "DVD" => "DVD",
        "SAT" => "SAT",
        "VTAPE" => "V.TAPE",
        "PC" => "PC",
        "DOORCAM" => "DOORCAM",
        "LIGHT" => "LIGHT",
        "AAUX" or "AAUX" => "A.AUX",
        "VAUX" or "VAUX" => "V.AUX",
        "ATAPE" => "A.TAPE",
        "ATAPE2" => "A.TAPE 2",
        "TEXT" => "TEXT",
        "SPDEMO" => "SPDEMO",
        _ => sourceName.ToUpperInvariant()
    };

    public void Dispose()
    {
        DeviceService.OnStatusChanged -= OnServiceStatusChanged;
        _scanCts?.Cancel();
        _scanCts?.Dispose();
    }
}
