@page "/"
@using System.Text.Json
@using BeoControl.Interfaces
@using BeoControlBlazor.Services
@using BeoControlBlazorServices
@using BeoControlBlazorCL.Remotes
@using BeoControlBlazorCL.Components;
@using Spotify
@inject DeviceService DeviceService
@inject NavigationManager Nav
@implements IDisposable


<PageTitle>B&amp;O Remote</PageTitle>

<div class="remote-shell">

    <div style="width:var(--remote-width); margin:0 auto;" class="remote-top">

        <div class="remote-toolbar">
        <div class="remote-switcher">
            @foreach (var r in Enum.GetValues<RemoteType>())
            {
                <label class="switcher-option @(Selected == r ? "active" : "")">
                    <input type="radio" name="remote" value="@r"
                           checked="@(Selected == r)"
                           @onchange="() => SelectRemote(r)" />
                    @RemoteLabel(r)
                </label>
            }
        </div>
            <button class="gear-btn" title="Setup" @onclick='() => Nav.NavigateTo("/setup")'>⚙</button>
            @* <button class="gear-btn" title="Zoom" @onclick='Zoom'>🔍</button> *@
        </div>
    </div>

    @if (Selected == RemoteType.Beolink1000)
    {
        <Beolink1000 OnCommand="SendCommand" DeviceStatus="@_status.Text" />
    }
    else
    {
        <Beo4 OnCommand="SendCommand" DeviceStatus="@_status.Text" Info="@_info" />
    }
    
    <div style="width:var(--remote-width); margin:0 auto;">
        <div style="padding:4px; height:3em;" class="conn-bar conn-bar--@(DeviceService.IsConnected ? "connected" : "disconnected")">
            <span class="conn-dot"></span>
            <span class="conn-text">@ConnectionLabel()</span>

       </div>
    </div>
</div>


@code {
    private RemoteType Selected;
    private StatusMessage _status = new(StatusType.Idle, "");
    private string _info = string.Empty;

    protected override void OnInitialized()
    {
        Selected = DeviceService.Settings.LastRemote;
        RemoteButton.Zoom = NormalizeZoom(DeviceService.Settings.RemoteButtonZoom);
        DeviceService.OnStatusChanged += OnStatusChanged;
    }

    private async void OnStatusChanged(StatusMessage msg)
    {
        if (msg.Kind == StatusKind.AudioSetup)
            return;

        if (msg.Kind == StatusKind.Source)
        {
            var sourceChanged = !string.Equals(_status.Text, msg.Text, StringComparison.Ordinal);
            _status = msg;

            if (sourceChanged)
            {
                _info = string.Empty;
                if (IsATapeSelected())
                {
                    var spotifyController = await GetSpotifyControllerAsync();
                    await spotifyController.RefreshNowPlayingAsync();
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose() => DeviceService.OnStatusChanged -= OnStatusChanged;

    private void SelectRemote(RemoteType r)
    {
        Selected = r;
        DeviceService.Settings.LastRemote = r;
        DeviceService.Settings.Save();
    }

    private Task<SpotifyController>? _spotifyControllerTask;

    private async Task SendCommand(string command)
    {
        DeviceService.SendCommand(command);

        var spotifyCommand = TryMapSpotifyCommand(command);
        if (spotifyCommand is null || !IsATapeSelected())
            return;

        var spotifyController = await GetSpotifyControllerAsync();
        await spotifyController.ExecuteAsync(spotifyCommand.Value);
    }

    private Task<SpotifyController> GetSpotifyControllerAsync() =>
        _spotifyControllerTask ??= ConnectSpotifyAsync();

    private async Task<SpotifyController> ConnectSpotifyAsync()
    {
        var settings = await LoadSpotifySettingsAsync();
        var connection = await SpotifyController.ConnectAsync(settings);
        var selectedDevice = SelectSpotifyDevice(connection.Devices, settings.PreferredDeviceName);

        var controller = new SpotifyController(
            connection.Client,
            connection.CurrentUserDisplayName,
            selectedDevice,
            OnSpotifyNowPlayingChanged);
        await controller.RefreshNowPlayingAsync();
        return controller;
    }

    private void OnSpotifyNowPlayingChanged(SpotifyNowPlaying? nowPlaying)
    {
        _ = InvokeAsync(() =>
        {
            _info = $"{nowPlaying?.Title ?? string.Empty} \n {nowPlaying?.Artist ?? string.Empty}";
            StateHasChanged();
        });
    }

