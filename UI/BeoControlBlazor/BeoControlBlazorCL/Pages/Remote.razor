    private static SpotifyAPI.Web.Device SelectSpotifyDevice(
        IReadOnlyList<SpotifyAPI.Web.Device> devices,
        string? preferredDeviceName)
    {
        if (devices.Count == 0)
            throw new InvalidOperationException("No Spotify playback device is available.");

        if (!string.IsNullOrWhiteSpace(preferredDeviceName))
        {
            return devices.FirstOrDefault(device =>
                       string.Equals(device.Name, preferredDeviceName, StringComparison.OrdinalIgnoreCase))
                   ?? throw new InvalidOperationException(
                       $"Preferred device '{preferredDeviceName}' was not found.");
        }

        return devices.FirstOrDefault(device => device.IsActive) ?? devices[0];
    }

    private bool IsATapeSelected() =>
        _status.Kind == StatusKind.Source &&
        (_status.Text.StartsWith("A.MEM", StringComparison.OrdinalIgnoreCase) ||
         _status.Text.StartsWith("A.TAPE", StringComparison.OrdinalIgnoreCase) ||
         _status.Text.StartsWith("ATAPE", StringComparison.OrdinalIgnoreCase));

    private static SpotifyPlaybackCommand? TryMapSpotifyCommand(string command) => command switch
    {
        "left" => SpotifyPlaybackCommand.Previous,
        "right" => SpotifyPlaybackCommand.Next,
        "stop" => SpotifyPlaybackCommand.Pause,
        "play" => SpotifyPlaybackCommand.Play,
        "go" => SpotifyPlaybackCommand.Play,

        _ => null
    };

    private string ConnectionLabel()
    {
        var dev = DeviceService.CurrentDevice;
        if (dev is null || !DeviceService.IsConnected)
            return "DISCONNECTED";

        var detail = dev.Type switch
        {
            DeviceType.USB => dev.Name is not null ? $"{dev.Name}  |  {dev.Id}" : dev.Id ?? "Serial",
            DeviceType.BT     => dev.Name is not null ? $"{dev.Name}  |  BT" : "BT",
            DeviceType.PC2    => "PC2",
            _                 => dev.Id ?? "Unknown"
        };
        return $"{detail}";
    }

    private static string RemoteLabel(RemoteType r) => r switch
    {
        RemoteType.Beolink1000 => "BL1000",
        RemoteType.Beo4        => "Beo4",
        _                      => r.ToString(),
    };
    private void Zoom(MouseEventArgs args)
    {
        RemoteButton.Zoom = RemoteButton.Zoom switch
        {
            100 => 150,
            150 => 200,
            _ => 100
        };
        DeviceService.Settings.RemoteButtonZoom = RemoteButton.Zoom;
        DeviceService.Settings.Save();
        StateHasChanged();
        Nav.NavigateTo("/", true);
    }

    private static int NormalizeZoom(int zoom) => zoom switch
    {
        100 or 150 or 200 => zoom,
        _ => 100
    };
}
