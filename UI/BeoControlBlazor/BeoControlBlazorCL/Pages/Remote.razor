@page "/"
@using BeoControl.Interfaces
@using BeoControlBlazor.Services
@using BeoControlBlazorServices
@using BeoControlBlazorCL.Remotes
@using BeoControlBlazorCL.Components
@using Spotify

@inject DeviceService DeviceService
@inject ILaunchSpotifyService LaunchSpotifyService
@inject NavigationManager Nav
@implements IDisposable


<PageTitle>B&amp;O Remote</PageTitle>

<div class="remote-shell" style="background-color:transparent">

    <div style="width:var(--remote-width); margin:0 auto;" class="remote-top">

        <div class="remote-toolbar">
        <div class="remote-switcher">
            @foreach (var r in Enum.GetValues<RemoteType>())
            {
                <label class="switcher-option @(Selected == r ? "active" : "")">
                    <input type="radio" name="remote" value="@r"
                           checked="@(Selected == r)"
                           @onchange="() => SelectRemote(r)" />
                    @RemoteLabel(r)
                </label>
            }
        </div>
            <button class="gear-btn" title="Setup" @onclick='() => Nav.NavigateTo("/setup")'>⚙</button>
            @* <button class="gear-btn" title="Zoom" @onclick='Zoom'>🔍</button> *@
        </div>
    </div>

    @if (Selected == RemoteType.Beolink1000)
    {
        <Beolink1000 OnCommand="SendCommand" DeviceStatus="@_status.Text" />
    }
    else
    {
        <Beo4 OnCommand="SendCommand" DeviceStatus="@_status.Text" Info="@_info" />
    }
    
    <div style="width:var(--remote-width); margin:0 auto;">
        <div style="padding:4px; height:3em;" class="conn-bar conn-bar--@(DeviceService.IsConnected ? "connected" : "disconnected")">
            <span class="conn-dot"></span>
            <span class="conn-text">@ConnectionLabel()</span>

       </div>
    </div>
</div>


@code {
    private const string SpotifyClientId = "d241779ec817475db4bf6b5bd0a457c7";
    private const string SpotifyRedirectUri = "http://127.0.0.1:5543/callback";

    private RemoteType Selected;
    private StatusMessage _status = new(StatusType.Idle, "");
    private string _info = string.Empty;
    private string _spotifyPreferredDeviceName = string.Empty;

    protected override void OnInitialized()
    {
        Selected = DeviceService.Settings.LastRemote;
        RemoteButton.Zoom = NormalizeZoom(DeviceService.Settings.RemoteButtonZoom);
        DeviceService.OnStatusChanged += OnStatusChanged;
    }

    private async void OnStatusChanged(StatusMessage msg)
    {
        if (msg.Kind == StatusKind.AudioSetup)
            return;

        if (msg.Kind == StatusKind.Source)
        {
            var sourceChanged = !string.Equals(_status.Text, msg.Text, StringComparison.Ordinal);
            _status = msg;

            if (sourceChanged)
            {
                _info = string.Empty;
                if (DeviceService.Settings.SpotifyEnabled && IsSpotifyTriggerSelected())
                {
                    var spotifyController = await GetSpotifyControllerAsync();
                    await spotifyController.RefreshNowPlayingAsync();
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DeviceService.OnStatusChanged -= OnStatusChanged;
        if (_spotifyControllerTask is { IsCompletedSuccessfully: true })
            _spotifyControllerTask.Result.Dispose();
    }

    private void SelectRemote(RemoteType r)
    {
        Selected = r;
        DeviceService.Settings.LastRemote = r;
        DeviceService.Settings.Save();
    }

    private Task<SpotifyController>? _spotifyControllerTask;

    private async Task SendCommand(string command)
    {
        if (command == "menu" &&   IsSpotifyTriggerSelected())
        {
            await OpenSpotifyAsync();
            return;
        }
        DeviceService.SendCommand(command);

        var spotifyCommand = TryMapSpotifyCommand(command);
        if (spotifyCommand is null || !DeviceService.Settings.SpotifyEnabled || !IsSpotifyTriggerSelected())
            return;

        var spotifyController = await GetSpotifyControllerAsync();
        await spotifyController.ExecuteAsync(spotifyCommand.Value);
    }

    private Task OpenSpotifyAsync()
    {
        return LaunchSpotifyService.OpenAsync(DeviceService.Settings.SpotifyLaunchMode);
    }


    private async Task<SpotifyController> GetSpotifyControllerAsync()
    {
        var preferredDeviceName = DeviceService.Settings.SpotifyPreferredDeviceName;
        if (!string.Equals(_spotifyPreferredDeviceName, preferredDeviceName, StringComparison.Ordinal))
        {
            await DisposeSpotifyControllerAsync();
            _spotifyControllerTask = null;
            _spotifyPreferredDeviceName = preferredDeviceName;
        }

        return await (_spotifyControllerTask ??= ConnectSpotifyAsync());
    }

    private async Task DisposeSpotifyControllerAsync()
    {
        if (_spotifyControllerTask is null)
            return;

        var controller = await _spotifyControllerTask;
        controller.Dispose();
    }

    private async Task<SpotifyController> ConnectSpotifyAsync()
    {
        if (!Uri.TryCreate(SpotifyRedirectUri, UriKind.Absolute, out var redirectUri)
            || !string.Equals(redirectUri.Scheme, Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase))
        {
            throw new InvalidOperationException("Spotify Redirect URI is invalid.");

        }

        var connection = await SpotifyController.ConnectAsync(SpotifyClientId, redirectUri.ToString());
        var selectedDevice = SelectSpotifyDevice(connection.Devices, DeviceService.Settings.SpotifyPreferredDeviceName);

        var controller = new SpotifyController(
            connection.Client,
            connection.CurrentUserDisplayName,
            selectedDevice,
            OnSpotifyNowPlayingChanged);
        await controller.ActivateSelectedDeviceAsync();
        await controller.RefreshNowPlayingAsync();
        return controller;
    }

    private void OnSpotifyNowPlayingChanged(SpotifyNowPlaying? nowPlaying)
    {
        _ = InvokeAsync(() =>
        {
            if (nowPlaying?.IsPlaying == true)
                _info = $"{nowPlaying.Title ?? string.Empty} \n {nowPlaying.Artist ?? string.Empty}";
            else
                _info = "Spotify is paused";
            StateHasChanged();
        });
    }

    private static SpotifyAPI.Web.Device SelectSpotifyDevice(
        IReadOnlyList<SpotifyAPI.Web.Device> devices,
        string? preferredDeviceName)
    {
        if (devices.Count == 0)
            throw new InvalidOperationException("No Spotify playback device is available.");

        if (!string.IsNullOrWhiteSpace(preferredDeviceName))
        {
            return devices.FirstOrDefault(device =>
                       string.Equals(device.Name, preferredDeviceName, StringComparison.OrdinalIgnoreCase))
                   ?? throw new InvalidOperationException(
                       $"Preferred device '{preferredDeviceName}' was not found.");
        }

        return devices.FirstOrDefault(device => device.IsActive) ?? devices[0];
    }

    private bool IsSpotifyTriggerSelected()
    {
        if (_status.Kind != StatusKind.Source)
            return false;

        var statusKey = NormalizeSourceKey(_status.Text);
        var triggerKey = NormalizeSourceKey(DeviceService.Settings.SpotifyTriggerCommand);
        if (string.IsNullOrEmpty(statusKey) || string.IsNullOrEmpty(triggerKey))
            return false;

        return GetSpotifyTriggerKeys(triggerKey).Any(statusKey.StartsWith);
    }

    private static string NormalizeSourceKey(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? string.Empty
            : new string(value.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();

    private static IEnumerable<string> GetSpotifyTriggerKeys(string triggerKey)
    {
        yield return triggerKey;

        switch (triggerKey)
        {
            case "ATAPE":
                yield return "AMEM";
                break;
            case "AMEM":
                yield return "ATAPE";
                break;
            case "ATAPE2":
                yield return "AMEM2";
                break;
            case "AMEM2":
                yield return "ATAPE2";
                break;
        }
    }

    private static SpotifyPlaybackCommand? TryMapSpotifyCommand(string command) => command switch
    {
        "left" => SpotifyPlaybackCommand.Previous,
        "right" => SpotifyPlaybackCommand.Next,
        "stop" => SpotifyPlaybackCommand.Pause,
        "play" => SpotifyPlaybackCommand.Play,
        "go" => SpotifyPlaybackCommand.Play,

        _ => null
    };

    private string ConnectionLabel()
    {
        var dev = DeviceService.CurrentDevice;
        if (dev is null || !DeviceService.IsConnected)
            return "DISCONNECTED";

        var detail = dev.Type switch
        {
            DeviceType.USB => dev.Name is not null ? $"{dev.Name}  |  {dev.Id}" : dev.Id ?? "Serial",
            DeviceType.BT     => dev.Name is not null ? $"{dev.Name}  |  BT" : "BT",
            DeviceType.PC2    => "PC2",
            _                 => dev.Id ?? "Unknown"
        };
        return $"{detail}";
    }

    private static string RemoteLabel(RemoteType r) => r switch
    {
        RemoteType.Beolink1000 => "BL1000",
        RemoteType.Beo4        => "Beo4",
        _                      => r.ToString(),
    };
    private void Zoom(MouseEventArgs args)
    {
        RemoteButton.Zoom = RemoteButton.Zoom switch
        {
            100 => 150,
            150 => 200,
            _ => 100
        };
        DeviceService.Settings.RemoteButtonZoom = RemoteButton.Zoom;
        DeviceService.Settings.Save();
        StateHasChanged();
        Nav.NavigateTo("/", true);
    }

    private static int NormalizeZoom(int zoom) => zoom switch
    {
        100 or 150 or 200 => zoom,
        _ => 100
    };
}
