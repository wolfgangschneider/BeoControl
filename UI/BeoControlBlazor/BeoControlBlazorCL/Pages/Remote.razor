@page "/"
@using BeoControl.Interfaces
@using BeoControlBlazor.Services
@using BeoControlBlazorServices
@using BeoControlBlazorCL.Remotes
@using BeoControlBlazorCL.Components

@inject DeviceService DeviceService
@inject ISpotifyService LaunchSpotifyService
@inject NavigationManager Nav
@implements IDisposable


<PageTitle>B&amp;O Remote</PageTitle>

<div class="remote-shell" style="background-color:transparent">

    <div style="width:var(--remote-width); margin:0 auto;" class="remote-top">

        <div class="remote-toolbar">
        <div class="remote-switcher">
            @foreach (var r in Enum.GetValues<RemoteType>())
            {
                <label class="switcher-option @(Selected == r ? "active" : "")">
                    <input type="radio" name="remote" value="@r"
                           checked="@(Selected == r)"
                           @onchange="() => SelectRemote(r)" />
                    @RemoteLabel(r)
                </label>
            }
        </div>
            <button class="gear-btn" title="Setup" @onclick='() => Nav.NavigateTo("/setup")'>⚙</button>
            @* <button class="gear-btn" title="Zoom" @onclick='Zoom'>🔍</button> *@
        </div>
    </div>

    @if (Selected == RemoteType.Beolink1000)
    {
        <Beolink1000 OnCommand="SendCommand" DeviceStatus="@_status.Text" />
    }
    else
    {
        <Beo4 OnCommand="SendCommand" DeviceStatus="@_status.Text" Info="@DisplayedInfo()" />
    }
    
    <div style="width:var(--remote-width); margin:0 auto;">
        <div style="padding:4px;" class="conn-bar conn-bar--@(DeviceService.IsConnected ? "connected" : "disconnected")">
            <div style="display:flex; flex-direction:column; gap:4px; width:100%;">
                <div style="display:flex; align-items:center; gap:6px;">
                    <span class="conn-dot"></span>
                    <span class="conn-text">@ConnectionLabel()</span>
                </div>
                @if (DeviceService.Settings.SpotifyEnabled)
                {
                    <div style="display:flex; align-items:center; gap:6px;" class="conn-row--@(SpotifyConnectionStateClass())">
                        <span class="conn-dot conn-row-dot--@(SpotifyConnectionStateClass())"></span>
                        <span class="conn-text">@SpotifyConnectionLabel()</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@code {
    private const string SpotifyAddInName = "Spotify";
    private static readonly BeoCommand[] SourceCommands =
        BeoCommands.All.Where(command => command.Category == CommandCategory.Source).ToArray();

    private RemoteType Selected;
    private StatusMessage _status = new(StatusType.Idle, "");
    private string _info = string.Empty;
    private string? _spotifyConnectedDeviceName;
    private BeoCommand? _currentSource;

    protected override void OnInitialized()
    {
        Selected = DeviceService.Settings.LastRemote;
        RemoteButton.Zoom = NormalizeZoom(DeviceService.Settings.RemoteButtonZoom);
        SyncSpotifySourceAddIn();
        DeviceService.OnStatusChanged += OnStatusChanged;
        _ = EnsureSpotifyConnectionStateAsync();
    }

    private async void OnStatusChanged(StatusMessage msg)
    {
        if (msg.Kind == StatusKind.AudioSetup)
            return;

        if (msg.Kind == StatusKind.Source)
        {
            var sourceChanged = !string.Equals(_status.Text, msg.Text, StringComparison.Ordinal);
            _status = msg;
            _currentSource = BeoCommands.ResolveSourceCommand(msg.Text) ?? _currentSource;

            if (sourceChanged)
            {
                if (DeviceService.Settings.SpotifyEnabled && IsSpotifySourceSelected())
                {
                    _spotifyConnectedDeviceName = await LaunchSpotifyService.GetSpotifyConnectedDeviceNameAsync(
                        DeviceService.Settings.SpotifyPreferredDeviceName);
                    _info = await LaunchSpotifyService.GetSpotifyNowPlayingTextAsync(
                        DeviceService.Settings.SpotifyPreferredDeviceName) ?? _info;
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DeviceService.OnStatusChanged -= OnStatusChanged;
    }

    private void SelectRemote(RemoteType r)
    {
        Selected = r;
        DeviceService.Settings.LastRemote = r;
        DeviceService.Settings.Save();
    }

    private async Task SendCommand(BeoCommand command)
    {
        if (command.Category == CommandCategory.Source)
            _currentSource = command;

        if (command.Id == CommandId.Menu && IsSpotifySourceSelected())
        {
            await OpenSpotifyAsync();
            return;
        }
        DeviceService.SendCommand(command.Cmd);

        var spotifyCommand = TryMapSpotifyCommand(command);
        if (spotifyCommand is null || !DeviceService.Settings.SpotifyEnabled || !IsSpotifySourceSelected())
            return;

        var executed = await LaunchSpotifyService.ExecuteSpotifyCommandAsync(
            spotifyCommand,
            DeviceService.Settings.SpotifyPreferredDeviceName);
        if (!executed)
            return;

        _spotifyConnectedDeviceName = await LaunchSpotifyService.GetSpotifyConnectedDeviceNameAsync(
            DeviceService.Settings.SpotifyPreferredDeviceName);
        _info = await LaunchSpotifyService.GetSpotifyNowPlayingTextAsync(
            DeviceService.Settings.SpotifyPreferredDeviceName) ?? _info;
        await InvokeAsync(StateHasChanged);
    }

    private Task OpenSpotifyAsync()
    {
        return LaunchSpotifyService.OpenAsync(DeviceService.Settings.SpotifyLaunchMode);
    }

    private async Task EnsureSpotifyConnectionStateAsync()
    {
        try
        {
            if (!DeviceService.Settings.SpotifyEnabled)
            {
                _spotifyConnectedDeviceName = null;
                await InvokeAsync(StateHasChanged);
                return;
            }

            _spotifyConnectedDeviceName = await LaunchSpotifyService.GetSpotifyConnectedDeviceNameAsync(
                DeviceService.Settings.SpotifyPreferredDeviceName);
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _spotifyConnectedDeviceName = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool IsSpotifySourceSelected()
    {
        return string.Equals(_currentSource?.AddIn, SpotifyAddInName, StringComparison.Ordinal);
    }

    private void SyncSpotifySourceAddIn()
    {
        foreach (var sourceCommand in SourceCommands)
            sourceCommand.AddIn = null;

        if (!DeviceService.Settings.SpotifyEnabled)
            return;

        var triggerCommand = BeoCommands.Find(DeviceService.Settings.SpotifyTriggerCommand);
        if (triggerCommand?.Category == CommandCategory.Source)
            triggerCommand.AddIn = SpotifyAddInName;
    }

    private static string? TryMapSpotifyCommand(BeoCommand command) => command.Id switch
    {
        CommandId.Left => "Previous",
        CommandId.Right => "Next",
        CommandId.Stop => "Pause",
        CommandId.Play => "Play",
        CommandId.Go => "Play",

        _ => null
    };

    private string DisplayedInfo() => IsSpotifySourceSelected() ? _info : string.Empty;

    private string ConnectionLabel()
    {
        var dev = DeviceService.CurrentDevice;
        if (dev is null || !DeviceService.IsConnected)
            return "DISCONNECTED";

        var detail = dev.Type switch
        {
            DeviceType.USB => dev.Name is not null ? $"{dev.Name}  |  {dev.Id}" : dev.Id ?? "Serial",
            DeviceType.BT     => dev.Name is not null ? $"{dev.Name}  |  BT" : "BT",
            DeviceType.PC2    => "PC2",
            _                 => dev.Id ?? "Unknown"
        };
        return $"{detail}";
    }

    private string SpotifyConnectionLabel()
    {
        if (!DeviceService.Settings.SpotifyEnabled)
            return "SPOTIFY DISABLED";

        if (!string.IsNullOrWhiteSpace(_spotifyConnectedDeviceName))
            return $"{_spotifyConnectedDeviceName}  |  SPOTIFY";

        if (!string.IsNullOrWhiteSpace(DeviceService.Settings.SpotifyPreferredDeviceName))
            return $"{DeviceService.Settings.SpotifyPreferredDeviceName}  |  SPOTIFY";

        return "SPOTIFY DISCONNECTED";
    }

    private string SpotifyConnectionStateClass()
    {
        if (!DeviceService.Settings.SpotifyEnabled)
            return "disconnected";

        return !string.IsNullOrWhiteSpace(_spotifyConnectedDeviceName)
            ? "connected"
            : "disconnected";
    }

    private static string RemoteLabel(RemoteType r) => r switch
    {
        RemoteType.Beolink1000 => "BL1000",
        RemoteType.Beo4        => "Beo4",
        _                      => r.ToString(),
    };
    private void Zoom(MouseEventArgs args)
    {
        RemoteButton.Zoom = RemoteButton.Zoom switch
        {
            100 => 150,
            150 => 200,
            _ => 100
        };
        DeviceService.Settings.RemoteButtonZoom = RemoteButton.Zoom;
        DeviceService.Settings.Save();
        StateHasChanged();
        Nav.NavigateTo("/", true);
    }

    private static int NormalizeZoom(int zoom) => zoom switch
    {
        100 or 150 or 200 => zoom,
        _ => 100
    };
}
