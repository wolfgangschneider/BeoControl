@* Pure layout component — no service knowledge *@

<div class="beo4">

    <div class="beo4-display-frame">
        <div class="beo4-display">
            <span class="beo4-display-source">@DisplayText</span>
        </div>
    </div>

    <div>
        <div class="beo4-section">
        <button class="beo4-btn" @onclick='() => SendCommand("tv")'>TV</button>
        <button class="beo4-btn" @onclick='() => SendCommand("light")'>LIGHT</button>
        <button class="beo4-btn" @onclick='() => SendCommand("radio")'>RADIO</button>

        <button class="beo4-btn" @onclick='() => SendCommand("sat")'>SAT</button>
        <button class="beo4-btn" @onclick='() => SendCommand("dvd")'>DVD</button>
        <button class="beo4-btn" @onclick='() => SendCommand("cd")'>CD</button>

        <button class="beo4-btn" @onclick='() => SendCommand("vtape")'>V.TAPE</button>
        <button class="beo4-btn" @onclick='() => SendCommand("record")'>RECORD</button>
        <button class="beo4-btn" @onclick='() => SendCommand("atape")'>A.TAPE</button>
    </div>

    <div class="beo4-section">
        <button class="beo4-btn" @onclick='() => SendCommand("7")'>7</button>
        <button class="beo4-btn" @onclick='() => SendCommand("8")'>8</button>
        <button class="beo4-btn" @onclick='() => SendCommand("9")'>9</button>

        <button class="beo4-btn" @onclick='() => SendCommand("4")'>4</button>
        <button class="beo4-btn" @onclick='() => SendCommand("5")'>5</button>
        <button class="beo4-btn" @onclick='() => SendCommand("6")'>6</button>

        <button class="beo4-btn" @onclick='() => SendCommand("1")'>1</button>
        <button class="beo4-btn" @onclick='() => SendCommand("2")'>2</button>
        <button class="beo4-btn" @onclick='() => SendCommand("3")'>3</button>

        <button class="beo4-btn" @onclick='() => SendCommand("text")'>TEXT</button>
        <button class="beo4-btn" @onclick='() => SendCommand("0")'>0</button>
        <button class="beo4-btn" @onclick='() => SendCommand("menu")'>MENU</button>
    </div>

    <div class="beo4-nav-area">
        <div class="beo4-nav">
            <button class="beo4-nav-btn" style="background:Green;width:30px;transform:rotate(-45deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand("green")'></button>
            <button style="z-index:10;transform: scaleX(2) " class="beo4-nav-btn beo4-nav-up" @onclick='() => SendCommand("up")'>▲</button>
            <button class="beo4-nav-btn" style="background:yellow;width:30px;transform:rotate(45deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand("yellow")'></button>

            <button style="z-index:10; transform: scaleY(2) " class="beo4-nav-btn beo4-nav-left" @onclick='() => SendCommand("left")'>◄</button>

            <div style="z-index:10; background:#1a1a1a;transform: scale(1.1);transform-origin: center center;">
                <button style="width:100%;" class="beo4-nav-btn beo4-nav-go" @onclick="OnGoPressed">GO</button>
           </div>

            <button class="beo4-nav-btn beo4-nav-right" style="z-index:10;transform: scaleY(2) " @onclick='() => SendCommand("right")'>►</button>

            <button class="beo4-nav-btn" style="background:Red;width:30px;transform:rotate(-135deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand("red")'></button>
            <button class="beo4-nav-btn beo4-nav-down" style="z-index:10;transform: scaleX(2) "  @onclick='() => SendCommand("down")'>▼</button>
            <button class="beo4-nav-btn" style="background:Blue;width:30px;transform:rotate(135deg) scaleY(1.5);margin:auto;"  @onclick='() => SendCommand("blue")'></button>
        </div>
    </div>

    <div class="beo4-section">
        <button class="beo4-btn" @onclick="OnListPressed">LIST</button>
        <button class="beo4-btn" @onclick='() => SendCommand("vol+")'>▲</button>
            <button class="beo4-btn" @onclick=' OnGoExit'>EXIT</button>

        <button class="beo4-btn" @onclick='() => SendCommand("stop")'>STOP</button>
        <button class="beo4-btn" @onclick='() => SendCommand("vol-")'>▼</button>
        <button class="beo4-btn beo4-red" @onclick='() => SendCommand("standby")'>&#9679;</button>
    </div>
    </div>

    <div class="beo4-footer">
        <span class="beo4-brand">BANG &amp; OLUFSEN</span>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public EventCallback<string> OnCommand { get; set; }
    [Parameter] public string? DeviceStatus { get; set; }

    private static string ExtractSource(string? status)
    {
        if (string.IsNullOrEmpty(status)) return "";
        foreach (var prefix in new[] { "sources:", "source:" })
        {
            var idx = status.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
            if (idx >= 0)
                return status[(idx + prefix.Length)..].Trim();
        }
        return status.Substring(0, Math.Min(8, status.Length));
    }

    private void SendCommand(string command) 
    {
        OnCommand.InvokeAsync(command);
        _listIndex = -1;
    }

    // Commands not on physical keys — cycled via LIST
    private static readonly List<(string Cmd, string Display)> AltList =
    [
        ("mute",     "MUTE"),
        ("pc",     "PC"),
        ("atape2",     "A.TAPE 2"),
        ("cd2",        "CD 2"),
        ("allstandby", "ALL STBY"),
        ("phono",      "PHONO"),
        ("speaker",      "SOUND"),

    ];

    private int _listIndex = -1;
    private bool InListMode => _listIndex >= 0;

    private string DisplayText =>
        InListMode ? AltList[_listIndex].Display : ExtractSource(DeviceStatus);

    private void OnListPressed()
    {
        _listIndex = InListMode ? (_listIndex + 1) % AltList.Count : 0;
    }

    private void OnGoPressed()
    {
        if (InListMode)
        {
           // do not reset list mode
            // SendCommand(AltList[_listIndex].Cmd);
            OnCommand.InvokeAsync(AltList[_listIndex].Cmd);
          
        }
        else SendCommand("go");
    }

    private void OnGoExit()
    {
        if (InListMode)
        {
            //SendCommand(AltList[_listIndex].Cmd);
            _listIndex = -1;
        }
        else SendCommand("exit");
    }

    private void OnExitPressed() { } // unused

    private void ToggleShift() { } // unused, kept to avoid rename cascades
}
