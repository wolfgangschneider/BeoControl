@using BeoControl.Interfaces
@using BeoControlBlazorCL.Components
@using Microsoft.AspNetCore.Components.Forms


<div class="beo4">

        <div class="beo4-display-frame">
        <div style="min-height:6rem" class="beo4-display">
            <span class="beo4-display-song">@Song</span>
            <span class="beo4-display-source">@DisplayText</span>
            <span class="beo4-display-info">@Info</span>
        </div>
    </div>

        <div>
            <div class="beo4-section">
            <RemoteButton CommandId="@CommandId.Tv" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Light" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Radio" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Sat" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Dvd" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Cd" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Vtape" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Record" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Atape" OnCommand="SendCommand" />
        </div>

        <div class="beo4-section">
            <RemoteButton CommandId="@CommandId.Digit7" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit8" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit9" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Digit4" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit5" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit6" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Digit1" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit2" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit3" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Text" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit0" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Menu" OnCommand="SendCommand" />
        </div>

        <div class="beo4-nav-area">
            <div class="beo4-nav">
            <button class="beo4-nav-btn" style="background:Green;width:30px;transform:rotate(-45deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand(CommandId.Green)'></button>
            <button style="z-index:10;transform: scaleX(2) " class="beo4-nav-btn beo4-nav-up" @onclick='() => SendCommand(CommandId.Up)'>▲</button>
            <button class="beo4-nav-btn" style="background:yellow;width:30px;transform:rotate(45deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand(CommandId.Yellow)'></button>

            <button style="z-index:10; transform: scaleY(2) " class="beo4-nav-btn beo4-nav-left" @onclick='() => SendCommand(CommandId.Left)'>◄</button>

                <div style="z-index:10; background:#1a1a1a;transform: scale(1.1);transform-origin: center center;">
                <button style="width:100%;" class="beo4-nav-btn beo4-nav-go" @onclick="OnGoPressed">GO</button>
                </div>

            <button class="beo4-nav-btn beo4-nav-right" style="z-index:10;transform: scaleY(2) " @onclick='() => SendCommand(CommandId.Right)'>►</button>

            <button class="beo4-nav-btn" style="background:Red;width:30px;transform:rotate(-135deg) scaleY(1.5);margin:auto;" @onclick='() => SendCommand(CommandId.Red)'></button>
            <button class="beo4-nav-btn beo4-nav-down" style="z-index:10;transform: scaleX(2) "  @onclick='() => SendCommand(CommandId.Down)'>▼</button>
            <button class="beo4-nav-btn" style="background:Blue;width:30px;transform:rotate(135deg) scaleY(1.5);margin:auto;"  @onclick='() => SendCommand(CommandId.Blue)'></button>
            </div>
        </div>

        <div class="beo4-section-volume">
            <RemoteButton style="grid-row:1; grid-column:1" OnClick="OnListPressed" Caption="LIST" />
            <div class="upBtn" style="grid-row:1; grid-column:2" >
                <RemoteButton style="border-radius: 3px 3px 0 0" CommandId="@CommandId.VolumeUp" OnCommand="SendCommand" Caption="▲" />
            </div>
            <RemoteButton style="grid-row:1; grid-column:3" OnClick="OnGoExit" Caption="EXIT" />
            <div class="muteBtn" style="grid-row:2;grid-column:2">
                <RemoteButton class="muteButtom" style=" border-radius:0; height:16px" CommandId="@CommandId.Mute" OnCommand="SendCommand" Caption="" />
            </div>

            <RemoteButton style="grid-row:3; grid-column:1" CommandId="@CommandId.Stop" OnCommand="SendCommand" />
            <div class="downBtn" style="grid-row:3; grid-column:2 ">
                <RemoteButton  style=" border-radius: 0 0 3px 3px  " CommandId="@CommandId.VolumeDown" OnCommand="SendCommand" Caption="▼" />

            </div>
            
            <div style="grid-row:3; grid-column:3 ">
                <StandbyButton  OnCommand="SendCommand" />
            </div>
        </div>
    </div>

    <div class="beo4-footer">
        <span class="beo4-brand">BANG &amp; OLUFSEN</span>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public EventCallback<BeoCommand> OnCommand { get; set; }
    [Parameter] public string? DeviceStatus { get; set; }
    [Parameter] public string? Song { get; set; }
    [Parameter] public string? Info { get; set; }

    private static string ExtractSource(string? status)
    {
        if (string.IsNullOrEmpty(status)) return "";
        foreach (var prefix in new[] { "sources:", "source:" })
        {
            var idx = status.IndexOf(prefix, StringComparison.OrdinalIgnoreCase);
            if (idx >= 0)
                return status[(idx + prefix.Length)..].Trim();
        }
        return status.Trim();
    }

    private Task SendCommand(CommandId commandId) => SendCommand(BeoCommands.Get(commandId));

    private Task SendCommand(BeoCommand command)
    {
        if (command.Category == CommandCategory.Source || command.Id == CommandId.Exit)
        {
            _activeList = _mainList;
            _listIndex = -1;
        }

        return OnCommand.InvokeAsync(command);
    }

    

    private readonly IReadOnlyList<BeoCommand> _mainList = AltList;
    private IReadOnlyList<BeoCommand> _activeList = [];
    private int _listIndex = -1;
    private bool InListMode => _listIndex >= 0;
    private bool InSubList => !ReferenceEquals(_activeList, _mainList);

    protected override void OnInitialized()
    {
        _activeList = _mainList;
    }

    private string DisplayText =>
        InListMode ? _activeList[_listIndex].RemoteLabel : ExtractSource(DeviceStatus);

    private void OnListPressed()
    {
        var list = InSubList ? _activeList : _mainList;
        if (list.Count == 0)
            return;

        _listIndex = InListMode ? (_listIndex + 1) % list.Count : 0;
    }

    private async Task OnGoPressed()
    {
        if (InListMode)
        {
            var selectedCommand = _activeList[_listIndex];
            if (!InSubList && selectedCommand.SubCommands is { Count: > 0 })
            {
                _activeList = selectedCommand.SubCommands;
                _listIndex = 0;
                await OnCommand.InvokeAsync(_activeList[_listIndex]);
                return;
            }

            if (InSubList)
            {
                // if(selectedCommand.Id == CommandId.Store)
                //     await OnCommand.InvokeAsync(BeoCommands.Get(CommandId.ASetup));

                await OnCommand.InvokeAsync(selectedCommand);
                return;
            }

            await SendCommand(selectedCommand);
            return;
        }

        await SendCommand(CommandId.Go);
    }

    private void OnGoExit()
    {
        if (InListMode)
        {
            _activeList = _mainList;
            _listIndex = 0;
        }
        else
        {
            _ = SendCommand(CommandId.Exit);
        }
    }

   
    private static List<BeoCommand> AltList
    {
        get
        {
            // var speakerCommand = BeoCommands.Get(CommandId.ASetup);
            // speakerCommand.AddSubcommands(
            //     BeoCommands.Get(CommandId.Speaker),
            //     BeoCommands.Get(CommandId.Balance),
            //     BeoCommands.Get(CommandId.Bass),
            //     BeoCommands.Get(CommandId.Treble),
            //     BeoCommands.Get(CommandId.Loudness),
              

                

            //     BeoCommands.Get(CommandId.Store));
            return
            [
               // speakerCommand,
                BeoCommands.Get(CommandId.Mute),
                BeoCommands.Get(CommandId.Phono),
                BeoCommands.Get(CommandId.Pc),
                BeoCommands.Get(CommandId.Atape2),
                BeoCommands.Get(CommandId.Cd2),
            ];
        }
    }

   


}
