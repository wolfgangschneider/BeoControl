@using BeoControlBlazorCL.Components
@* Pure layout component — no service knowledge *@

<div class="bl1000">
    <div class="bl1000-header"></div>

    <div>
        <div class="bl1000-section">
            <RemoteButton Cmd="tv" OnCommand="SendCommand" Caption="TV" />
            <RemoteButton Cmd="light" OnCommand="SendCommand" Caption="LIGHT" />
            <RemoteButton Cmd="radio" OnCommand="SendCommand" Caption="RADIO" />

            <RemoteButton Cmd="sat" OnCommand="SendCommand" Caption="SAT" />
            <RemoteButton Cmd="link" OnCommand="SendCommand" Caption="LINK" />
            <RemoteButton Cmd='@Cmd("cd")' OnCommand="SendCommand" Caption='@Label("cd")' />

            <RemoteButton Cmd="vtape" OnCommand="SendCommand" Caption="V.TAPE" />
            <RemoteButton Cmd="record" OnCommand="SendCommand" Caption="RECORD" />
            <RemoteButton Cmd='@Cmd("atape")' OnCommand="SendCommand" Caption='@Label("atape")' />

            <RemoteButton Cmd="menu" OnCommand="SendCommand" Caption="MENU" />
            <RemoteButton style="@ShiftButtonStyle" OnClick="ToggleShift" Caption="SHIFT" />
            <RemoteButton Cmd='@Cmd("phono")' OnCommand="SendCommand" Caption='@Label("phono")' />
        </div>

        <div class="bl1000-section">
            <RemoteButton Cmd="stop" OnCommand="SendCommand" Caption="STOP" />
            <RemoteButton Cmd="up" OnCommand="SendCommand" Caption="▲" />
            <RemoteButton Cmd="play" OnCommand="SendCommand" Caption="PLAY" />

            <RemoteButton Cmd="left" OnCommand="SendCommand" Caption="<<" />
            <RemoteButton Cmd="down" OnCommand="SendCommand" Caption="▼" />
            <RemoteButton Cmd="right" OnCommand="SendCommand" Caption=">>" />
        </div>

        <div class="bl1000-section">
            <RemoteButton Cmd="7" OnCommand="SendCommand" Caption="7" />
            <RemoteButton Cmd="8" OnCommand="SendCommand" Caption="8" />
            <RemoteButton Cmd="9" OnCommand="SendCommand" Caption="9" />

            <RemoteButton Cmd="4" OnCommand="SendCommand" Caption="4" />
            <RemoteButton Cmd="5" OnCommand="SendCommand" Caption="5" />
            <RemoteButton Cmd="6" OnCommand="SendCommand" Caption="6" />

            <RemoteButton Cmd="1" OnCommand="SendCommand" Caption="1" />
            <RemoteButton Cmd="2" OnCommand="SendCommand" Caption="2" />
            <RemoteButton Cmd="3" OnCommand="SendCommand" Caption="3" />

            <RemoteButton Cmd="text" OnCommand="SendCommand" Caption="TEXT" />
            <RemoteButton Cmd="0" OnCommand="SendCommand" Caption="0" />
            <RemoteButton Cmd="goto" OnCommand="SendCommand" Caption="GO TO" disabled />
        </div>

        <div class="bl1000-section">
            <RemoteButton Cmd="picture" OnCommand="SendCommand" Caption="PICTURE" />
            <span></span>
            <RemoteButton Cmd="vol+" OnCommand="SendCommand" Caption="▲" />

            <RemoteButton Cmd="store" OnCommand="SendCommand" Caption="STORE" />
            <span></span>
            <span></span>

            <RemoteButton Cmd="speaker" OnCommand="SendCommand" Caption="SOUND" />
            <span></span>
            <RemoteButton Cmd="vol-" OnCommand="SendCommand" Caption="▼" />
        </div>

        <div class="bl1000-section">
            <RemoteButton Cmd="av" OnCommand="SendCommand" Caption="AV" />
            <StandbyButton OnCommand="SendCommand" />
            <RemoteButton Cmd="mute" OnCommand="SendCommand" Caption="MUTE" />
        </div>

    </div>
    <div class="bl1000-footer">
        <span class="bl1000-brand">BANG &amp; OLUFSEN</span>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public EventCallback<string> OnCommand { get; set; }
    [Parameter] public string? DeviceStatus { get; set; }

    private static readonly Dictionary<string, string> AltMap = new()
    {
        ["atape"]   = "atape2",
        ["cd"]      = "cd2",

        ["mute"]    = "loudness",
        ["phono"]   = "pc",
    };

    private bool _shifted;

    private string Cmd(string primary) =>
        _shifted && AltMap.TryGetValue(primary, out var alt) ? alt : primary;

    private string Label(string primary) =>
        (_shifted && AltMap.TryGetValue(primary, out var alt) ? alt : primary).ToUpper()
        .Replace("ATAPE", "A.TAPE");

    private void ToggleShift() => _shifted = !_shifted;

    private Task SendCommand(string command) => OnCommand.InvokeAsync(command);

    private string? ShiftButtonStyle => _shifted ? "background:#555;outline:1px solid #aaa;" : null;
}
