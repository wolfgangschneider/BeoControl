@using BeoControl.Interfaces
@using BeoControlBlazorCL.Components
@* Pure layout component — no service knowledge *@

<div class="bl1000">
    <div class="bl1000-header"></div>

    <div>
        <div class="bl1000-section">
            <RemoteButton CommandId="@CommandId.Tv" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Light" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Radio" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Sat" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Link" OnCommand="SendCommand" />
            <RemoteButton CommandId="@ShiftedCommandId(CommandId.Cd)" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Vtape" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Record" OnCommand="SendCommand" />
            <RemoteButton CommandId="@ShiftedCommandId(CommandId.Atape)" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Menu" OnCommand="SendCommand" />
            <RemoteButton style="@ShiftButtonStyle" OnClick="ToggleShift" Caption="SHIFT" />
            <RemoteButton CommandId="@ShiftedCommandId(CommandId.Phono)" OnCommand="SendCommand" />
        </div>

        <div class="bl1000-section">
            <RemoteButton CommandId="@CommandId.Stop" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Up" OnCommand="SendCommand" Caption="▲" />
            <RemoteButton CommandId="@CommandId.Play" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Left" OnCommand="SendCommand" Caption="<<" />
            <RemoteButton CommandId="@CommandId.Down" OnCommand="SendCommand" Caption="▼" />
            <RemoteButton CommandId="@CommandId.Right" OnCommand="SendCommand" Caption=">>" />
        </div>

        <div class="bl1000-section">
            <RemoteButton CommandId="@CommandId.Digit7" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit8" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit9" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Digit4" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit5" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit6" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Digit1" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit2" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit3" OnCommand="SendCommand" />

            <RemoteButton CommandId="@CommandId.Text" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Digit0" OnCommand="SendCommand" />
            <RemoteButton CommandId="@CommandId.Goto" OnCommand="SendCommand" disabled />
        </div>

        <div class="bl1000-section">
            <RemoteButton CommandId="@CommandId.Picture" OnCommand="SendCommand" />
            <span></span>
            <RemoteButton CommandId="@CommandId.VolumeUp" OnCommand="SendCommand" Caption="▲" />

            <RemoteButton CommandId="@CommandId.Store" OnCommand="SendCommand" />
            <span></span>
            <span></span>

            <RemoteButton CommandId="@CommandId.Speaker" OnCommand="SendCommand" />
            <span></span>
            <RemoteButton CommandId="@CommandId.VolumeDown" OnCommand="SendCommand" Caption="▼" />
        </div>

        <div class="bl1000-section">
            <RemoteButton CommandId="@CommandId.Av" OnCommand="SendCommand" />
            <StandbyButton OnCommand="SendCommand" />
            <RemoteButton CommandId="@ShiftedCommandId(CommandId.Mute)" OnCommand="SendCommand" />
        </div>

    </div>
    <div class="bl1000-footer">
        <span class="bl1000-brand">BANG &amp; OLUFSEN</span>
    </div>

</div>

@code {
    [Parameter, EditorRequired] public EventCallback<BeoCommand> OnCommand { get; set; }
    [Parameter] public string? DeviceStatus { get; set; }

    private bool _shifted;

    private void ToggleShift() => _shifted = !_shifted;

    private Task SendCommand(BeoCommand command) => OnCommand.InvokeAsync(command);

    private string? ShiftButtonStyle => _shifted ? "background:#555;outline:1px solid #aaa;" : null;

    private CommandId ShiftedCommandId(CommandId commandId) => !_shifted ? commandId : commandId switch
    {
        CommandId.Cd => CommandId.Cd2,
        CommandId.Phono => CommandId.Pc,
        CommandId.Atape => CommandId.Atape2,
        CommandId.Mute => CommandId.Loudness,
        _ => commandId,
    };
}
