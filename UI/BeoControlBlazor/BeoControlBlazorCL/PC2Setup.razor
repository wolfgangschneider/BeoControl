@using Microsoft.AspNetCore.Components.Forms
@inject BeoControlBlazorServices.DeviceService DeviceService
@implements IDisposable

<div class="pc2-setup">
    <section class="pc2-card">
        <div class="pc2-card-header">
            <div>
                <h3 class="pc2-card-title">Sound</h3>
                <p class="pc2-card-subtitle">Fine tune the PC2 audio profile.</p>
            </div>
        </div>

        <div class="pc2-sound-grid">
            <span class="pc2-setting-label">Volume</span>
            <input class="pc2-value-box" value="@CurrentVolume" readonly />
            <button class="pc2-rocker-btn" aria-label="Decrease volume" @onclick='() => SendCommand("vol-")'>-</button>
            <button class="pc2-rocker-btn" aria-label="Increase volume" @onclick='() => SendCommand("vol+")'>+</button>

            <span class="pc2-setting-label">Bass</span>
            <input class="pc2-value-box" value="@CurrentBass" readonly />
            <button class="pc2-rocker-btn" aria-label="Decrease bass" @onclick='() => SendCommand("bas-")'>-</button>
            <button class="pc2-rocker-btn" aria-label="Increase bass" @onclick='() => SendCommand("bas+")'>+</button>

            <span class="pc2-setting-label">Treble</span>
            <input class="pc2-value-box" value="@CurrentTreble" readonly />
            <button class="pc2-rocker-btn" aria-label="Decrease treble" @onclick='() => SendCommand("tre-")'>-</button>
            <button class="pc2-rocker-btn" aria-label="Increase treble" @onclick='() => SendCommand("tre+")'>+</button>

            <span class="pc2-setting-label">Loudness</span>
            <input class="pc2-value-box" value="@CurrentLoudness" readonly />
            <button class="pc2-rocker-btn" aria-label="Decrease loudness" @onclick='() => SendCommand("lou-")'>-</button>
            <button class="pc2-rocker-btn" aria-label="Increase loudness" @onclick='() => SendCommand("lou+")'>+</button>
        </div>
    </section>

    <section class="pc2-card">
        <div class="pc2-card-header">
            <div>
                <h3 class="pc2-card-title">Option</h3>
                <p class="pc2-card-subtitle">Select the PC2 option profile.</p>
            </div>
        </div>

        <InputRadioGroup @bind-Value="Option" Name="pc2-option">
            <div class="pc2-choice-grid">
                @foreach (var option in OptionValues)
                {
                    <label class="pc2-choice @(Option == option ? "active" : "")">
                        <InputRadio class="pc2-radio" Value="option" />
                        <span>@option</span>
                    </label>
                }
            </div>
        </InputRadioGroup>
    </section>

    <section class="pc2-card">
        <div class="pc2-card-header">
            <div>
                <h3 class="pc2-card-title">Default source</h3>
                <p class="pc2-card-subtitle">Choose which source the system powers up with.</p>
            </div>
        </div>

        <InputRadioGroup @bind-Value="DefaultSource" Name="pc2-default-source">
            <div class="pc2-choice-grid pc2-choice-grid-wide">
                @foreach (var source in DefaultSources)
                {
                    <label class="pc2-choice @(DefaultSource == source.Value ? "active" : "")">
                        <InputRadio class="pc2-radio" Value="source.Value" />
                        <span>@source.Label</span>
                    </label>
                }
            </div>
        </InputRadioGroup>
    </section>
</div>

@code {
    private static readonly int[] OptionValues = [0, 2, 4, 6];

    private static readonly (int Value, string Label)[] DefaultSources =
    [
        (0, "PC"),
        (1, "None")
    ];

    public int Option { get; set; }
    public int DefaultSource { get; set; }

    private string CurrentVolume => DeviceService.CurrentPc2AudioSetup.Volume.ToString();
    private string CurrentBass => FormatSigned(DeviceService.CurrentPc2AudioSetup.Bass);
    private string CurrentTreble => FormatSigned(DeviceService.CurrentPc2AudioSetup.Treble);
    private string CurrentLoudness => DeviceService.CurrentPc2AudioSetup.Loudness ? "On" : "Off";

    private static string FormatSigned(sbyte? value) =>
        value is null ? "--" : value.Value.ToString("+0;-0;0");

    protected override void OnInitialized()
    {
        DeviceService.OnStatusChanged += OnStatusChanged;
    }

    private void SendCommand(string command) => DeviceService.SendCommand(command);

    private async void OnStatusChanged(BeoControl.Interfaces.StatusMessage _)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DeviceService.OnStatusChanged -= OnStatusChanged;
    }
}
